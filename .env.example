# --- Core ---
DATABASE_URL="postgresql://attestor:attestor@localhost:5434/attestor?schema=public"
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# --- Auth (M0-4) ---
AUTH_SECRET=""                      # openssl rand -base64 32
# EMAIL_SERVER=""                   # magic-link SMTP url
# GITHUB_OAUTH_CLIENT_ID=""
# GITHUB_OAUTH_CLIENT_SECRET=""

# --- Secrets / crypto (M1) ---
# MASTER_ENCRYPTION_KEY=""          # 32-byte base64 (self-host); KMS in SaaS

# --- GitHub App (M1) ---
# GITHUB_APP_ID=""
# GITHUB_APP_PRIVATE_KEY=""
# GITHUB_APP_WEBHOOK_SECRET=""

# --- Spec sync (M2/M8) ---
SPEC_SOURCE_REPO="appdefensealliance/ASA-WG"
SPEC_SOURCE_PATH="CASA/CASA Specification.md"
SPEC_TRACKED_REF="develop"
SPEC_AUTO_PUBLISH="false"

# --- Default LLM (M1) ---
DEFAULT_LLM_PROVIDER="anthropic"
