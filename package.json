{
  "name": "attestor",
  "version": "0.0.1",
  "private": true,
  "description": "Open-source, multi-tenant platform to prepare for a Google/App Defense Alliance CASA Tier 2 self-assessment.",
  "license": "Apache-2.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "npm run generate -w @attestor/db",
    "db:push": "npm run push -w @attestor/db",
    "db:migrate": "npm run migrate -w @attestor/db",
    "db:seed": "npm run seed -w @attestor/db"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
